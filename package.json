{
  "name": "auction-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "npm run dev --workspace @auction-manager/server",
    "dev:web": "npm run dev --workspace @auction-manager/web",
    "dev:server": "npm run dev --workspace @auction-manager/server",
    "start:event": "npm run build && npm run start --workspace @auction-manager/server",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:unit": "vitest run apps/server/src/dependencies.test.ts apps/web/src/dependencies.test.ts packages/imports/src/dependencies.test.ts packages/persistence/src/dependencies.test.ts packages/shared/src/dependencies.test.ts",
    "test:integration": "vitest run apps/server/src/app.test.ts packages/shared/src/workspace-boundaries.test.ts",
    "test:watch": "vitest",
    "test:e2e": "npm run build --workspace @auction-manager/web && playwright test",
    "test:e2e:event": "playwright test --config playwright.event.config.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.0",
    "vite": "^8.1.2",
    "vitest": "^4.1.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
